<mujoco model="scissors_cut_scene">
  <compiler angle="degree" autolimits="true"/>
  <option timestep="0.002" gravity="0 0 -9.81"/>
  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <global azimuth="120" elevation="-20"/>
  </visual>
  <asset>
    <texture name="floor_tex" type="2d" builtin="checker" width="512" height="512"
             rgb1="0.25 0.25 0.25" rgb2="0.35 0.35 0.35"/>
    <material name="floor_mat" texture="floor_tex" texrepeat="4 4" reflectance="0.2"/>
  </asset>
  <include file="dexterous_hand.xml"/>
  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" diffuse="0.8 0.8 0.8"/>
    <light pos="0.5 0.5 1.0" dir="-0.3 -0.3 -1" diffuse="0.5 0.5 0.5"/>
    <geom name="floor" type="plane" size="2 2 0.05" material="floor_mat" condim="3"/>

    <body name="scissors" pos="0.08 0.05 0.18">
      <freejoint name="scissors_free"/>
      <body name="blade_a" pos="0 0 0">
        <geom name="blade_a_geom" type="box" size="0.003 0.06 0.008" mass="0.01"
              friction="1.2 0.005 0.0001" rgba="0.75 0.75 0.8 1"/>
      </body>
      <body name="blade_b" pos="0 0 0">
        <joint name="scissor_hinge" type="hinge" axis="0 0 1" range="0 45" damping="0.02"/>
        <geom name="blade_b_geom" type="box" size="0.003 0.06 0.008" mass="0.01"
              friction="1.2 0.005 0.0001" rgba="0.7 0.7 0.75 1"/>
      </body>
      <site name="object_site" pos="0 0.05 0" size="0.008"/>
    </body>

    <body name="paper" pos="0.1 0.05 0.12">
      <geom name="paper_geom" type="box" size="0.06 0.04 0.0005" mass="0.002"
            friction="0.5 0.005 0.0001" rgba="0.95 0.95 0.9 1" solref="0.02 1" solimp="0.9 0.95 0.001"/>
    </body>

    <site name="target" pos="0.1 0.05 0.12" size="0.02" rgba="1 0 0 0.3"/>
  </worldbody>
</mujoco>
